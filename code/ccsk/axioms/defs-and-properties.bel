%%% Definitions needed to state the axioms (lines 4-117);               %%%
%%% Properties of the LTS of CCSKP to prove the axioms (lines 120-1990) %%%

%%% Inverse of a transition

% Inverse of a transition: ccsk_inv_tr S1 S2 holds iff S2 is the inverse of S1
LF ccsk_inv_tr: ccsk.step X KL1 X' → ccsk.step Y KL2 Y' → type =
  | ccsk_it: {S1:ccsk.step X KL X'} {S2:ccsk.step X' KL X} ccsk_inv_tr S1 S2
;

% We show that, thanks to the loop lemma, ccsk_inv_tr is a function and, in particular, an involution (ccsk_inv_tr ∘ ccsk_inv_tr = id).
% Additionally, we show that t and inv_tr(t) have opposite directions.

% Existential type denoting existence of an inverse transition
LF ccsk_ex_inv: ccsk.step X KL X' → type =
  | ccsk_ex_iv: ccsk_inv_tr S1 S2 → ccsk_ex_inv S1
;

% Totality of ccsk_inv_tr: given a transition S,
% there exists at least one transition S' such that ccsk_inv_tr(S)=S'.
rec ccsk_total_inv: (g:ctx) {S:[g ⊢ ccsk.step X KL X']} [g ⊢ ccsk_ex_inv S] =
/ total (ccsk_total_inv) /
mlam S ⇒ case [_ ⊢ S] of
  | [g ⊢ fw F] ⇒ let [g ⊢ B] = ccsk_loop_lemma_one [g ⊢ F] in [g ⊢ ccsk_ex_iv (ccsk_it S (bw B))]
  | [g ⊢ bw B] ⇒ let [g ⊢ F] = ccsk_loop_lemma_two [g ⊢ B] in [g ⊢ ccsk_ex_iv (ccsk_it S (fw F))]
;

% Functionality of inv_tr: given a transition S,
% there is at most one transition S' such that inv_tr(S)=S'.
rec ccsk_functional_inv: (g:ctx) (S:[g ⊢ ccsk.step X KL X']) (S1:[g ⊢ ccsk.step Y1 KL1 Y1']) (S2:[g ⊢ ccsk.step Y2 KL2 Y2'])
  [g ⊢ ccsk_inv_tr S S1] → [g ⊢ ccsk_inv_tr S S2] → [g ⊢ eqs S1 S2] =
/ total r1 (ccsk_functional_inv _ _ _ _ r1 _) /
fn r1,r2 ⇒ let [g ⊢ ccsk_it _ S1] = r1 in
let [g ⊢ ccsk_it _ S2] = r2 in ccsk_unique_step [g ⊢ S1] [g ⊢ S2]
;

% inv_tr is an involution: inv_tr ∘ inv_tr = id.
rec ccsk_involution_inv: (g:ctx) (S1:[g ⊢ ccsk.step X1 KL1 X1']) (S2:[g ⊢ ccsk.step X2 KL2 X2'])
  (S3:[g ⊢ ccsk.step X3 KL3 X3']) [g ⊢ ccsk_inv_tr S1 S2] → [g ⊢ ccsk_inv_tr S2 S3] → [g ⊢ eqs S1 S3] =
/ total s1 (ccsk_involution_inv _ _ _ _ _ _ _ _ _ _ s1 _ _ _ _) /
fn d1,d2 ⇒ let [g ⊢ ccsk_it S1 S2] = d1 in
let [g ⊢ ccsk_it S2 S3] = d2 in ccsk_unique_step [g ⊢ S1] [g ⊢ S3]
;


%%% Same and opposite direction of transitions

% Type family relating two combined CCSK transitions having the same direction
LF ccsk_same_direction: ccsk.step X1 KL1 Y1 → ccsk.step X2 KL2 Y2 → type =
  | ccsk_sdf: ccsk_same_direction (fw F1) (fw F2)
  | ccsk_sdb: ccsk_same_direction (bw B1) (bw B2)
;

% Type family relating two combined transitions having opposite directions
LF ccsk_opp_direction: ccsk.step X1 KL1 Y1 → ccsk.step X2 KL2 Y2 → type =
  | ccsk_odfb: ccsk_opp_direction (fw F1) (bw B2)
  | ccsk_odbf: ccsk_opp_direction (bw B1) (fw F2)
;

% Type family relating couples of combined transitions with same or opposite directions
LF ex_ccsk_same_or_opp_direction: ccsk.step X1 KL1 Y1 → ccsk.step X2 KL2 Y2 → type =
  | ccsk_or_sd: ccsk_same_direction S1 S2 → ex_ccsk_same_or_opp_direction S1 S2
  | ccsk_or_od: ccsk_opp_direction S1 S2 → ex_ccsk_same_or_opp_direction S1 S2
;

% Given two combined transitions, they either have the same direction or opposite directions.
rec ccsk_same_or_opp_direction: (g:ctx) {S1:[g ⊢ ccsk.step X1 KL1 X1']} {S2:[g ⊢ ccsk.step X2 KL2 X2']}
  [g ⊢ ex_ccsk_same_or_opp_direction S1 S2] =
/ total s1 (ccsk_same_or_opp_direction _ _ _ _ _ _ _ s1 _ ) /
mlam S1,S2 ⇒ case [_ ⊢ S1] of
  | [g ⊢ fw F1] ⇒ (case [g ⊢ S2] of
       | [g ⊢ fw F2] ⇒ [g ⊢ ccsk_or_sd ccsk_sdf]
       | [g ⊢ bw B2] ⇒ [g ⊢ ccsk_or_od ccsk_odfb])
  | [g ⊢ bw B1] ⇒ (case [g ⊢ S2] of
       | [g ⊢ fw F2] ⇒ [g ⊢ ccsk_or_od ccsk_odbf]
       | [g ⊢ bw B2] ⇒ [g ⊢ ccsk_or_sd ccsk_sdb])
;

% Given two combined transitions, they cannot both have the same direction and opposite directions.
rec ccsk_not_same_and_opp_direction: (g:ctx) (S1:[g ⊢ ccsk.step X1 KL1 X1']) (S2:[g ⊢ ccsk.step X2 KL2 X2'])
  [g ⊢ ccsk_same_direction S1 S2] → [g ⊢ ccsk_opp_direction S1 S2] → [g ⊢ false] =
/ total sd (ccsk_not_same_and_opp_direction _ _ _ _ _ _ _ _ _ sd _) /
fn sd,od ⇒ case sd of
  | [g ⊢ ccsk_sdf] ⇒ impossible od
  | [g ⊢ ccsk_sdb] ⇒ impossible od
;

% Given a combined transition S, it has the same direction as itself.
rec reflexive_ccsk_same_direction: (g:ctx) {S:[g ⊢ ccsk.step X KL Y]} [g ⊢ ccsk_same_direction S S] =
/ total (reflexive_ccsk_same_direction) /
mlam S ⇒ case [_ ⊢ S] of
  | [g ⊢ fw F] ⇒ [g ⊢ ccsk_sdf]
  | [g ⊢ bw B] ⇒ [g ⊢ ccsk_sdb]
;

% If two combined transitions S1 and S2 have same directions, then S2 and S1 have the same directions.
rec symmetric_ccsk_same_direction: (g:ctx) (S1:[g ⊢ ccsk.step X1 KL1 X1']) (S2:[g ⊢ ccsk.step X2 KL2 X2'])
  [g ⊢ ccsk_same_direction S1 S2] → [g ⊢ ccsk_same_direction S2 S1] =
/ total (symmetric_ccsk_same_direction) /
fn sd ⇒ case sd of
  | [g ⊢ ccsk_sdf] ⇒ [g ⊢ ccsk_sdf]
  | [g ⊢ ccsk_sdb] ⇒ [g ⊢ ccsk_sdb]
;

% If S1 and S2 have same directions, and S2 and S3 have same directions, then S1 and S3 have same directions.
rec transitive_ccsk_same_direction: (g:ctx) (S1:[g ⊢ ccsk.step X1 KL1 X1']) (S2:[g ⊢ ccsk.step X2 KL2 X2'])
  (S3:[g ⊢ ccsk.step X3 KL3 X3']) [g ⊢ ccsk_same_direction S1 S2] → [g ⊢ ccsk_same_direction S2 S3] →
  [g ⊢ ccsk_same_direction S1 S3] =
/ total (transitive_ccsk_same_direction) /
fn sd1,sd2 ⇒ case sd1 of
  | [g ⊢ ccsk_sdf] ⇒ let [g ⊢ ccsk_sdf] = sd2 in [g ⊢ ccsk_sdf]
  | [g ⊢ ccsk_sdb] ⇒ let [g ⊢ ccsk_sdb] = sd2 in [g ⊢ ccsk_sdb]
;

% Given a combined transition t, t and inv_tr(t) have opposite directions.
% We postpone the proof of this result to the end of the file, in order to exploit one of the lemmas
% that will be proved below.


%%% Auxiliary lemmas

% If a process X makes a forward transition F into the process X',
% and a key K does not occur in X' (i.e., notin K X' holds), then K does
% not occur in X as well (notin K X).
rec notin_propagates_to_source: (g:ctx) [g ⊢ ccsk.fstep X KL X'] →
   [g ⊢ notin K[] X'] → [g ⊢ notin K[] X] =
/ total f (notin_propagates_to_source _ _ _ _ _ f _) /
fn f,n ⇒ case f of
  | [g ⊢ fs_pref _] ⇒ let [g ⊢ not_kpref _ N] = n in [g ⊢ not_pref N]
  | [g ⊢ fs_kpref F _] ⇒ let [g ⊢ not_kpref I N] = n in
    let [g ⊢ N'] = notin_propagates_to_source [g ⊢ F] [g ⊢ N] in [g ⊢ not_kpref I N']
  | [g ⊢ fs_suml F1 _] ⇒ let [g ⊢ not_sum N1 N2] = n in
    let [g ⊢ N1'] = notin_propagates_to_source [g ⊢ F1] [g ⊢ N1] in [g ⊢ not_sum N1' N2]
  | [g ⊢ fs_sumr F2 _] ⇒ let [g ⊢ not_sum N1 N2] = n in
    let [g ⊢ N2'] = notin_propagates_to_source [g ⊢ F2] [g ⊢ N2] in [g ⊢ not_sum N1 N2']
  | [g ⊢ fs_parl F1 _] ⇒ let [g ⊢ not_par N1 N2] = n in
    let [g ⊢ N1'] = notin_propagates_to_source [g ⊢ F1] [g ⊢ N1] in [g ⊢ not_par N1' N2]
  | [g ⊢ fs_parr F2 _] ⇒ let [g ⊢ not_par N1 N2] = n in
    let [g ⊢ N2'] = notin_propagates_to_source [g ⊢ F2] [g ⊢ N2] in [g ⊢ not_par N1 N2']
  | [g ⊢ fs_synl F1 F2] ⇒ let [g ⊢ not_par N1 N2] = n in
    let [g ⊢ N1'] = notin_propagates_to_source [g ⊢ F1] [g ⊢ N1] in
    let [g ⊢ N2'] = notin_propagates_to_source [g ⊢ F2] [g ⊢ N2] in [g ⊢ not_par N1' N2']
  | [g ⊢ fs_synr F1 F2] ⇒ let [g ⊢ not_par N1 N2] = n in
    let [g ⊢ N1'] = notin_propagates_to_source [g ⊢ F1] [g ⊢ N1] in
    let [g ⊢ N2'] = notin_propagates_to_source [g ⊢ F2] [g ⊢ N2] in [g ⊢ not_par N1' N2']
  | [g ⊢ fs_nu \a.F] ⇒ let [g ⊢ not_nu \a.N] = n in
    let [g,a:names ⊢ N'] = notin_propagates_to_source [_ ⊢ F] [_ ⊢ N] in [g ⊢ not_nu \a.N']
;

% If a process X makes a forward transition F via the keyed label α[M]
% into the process X', a key K does not occur in X (i.e., notin K X holds),
% and M is different from K, then K does not occur in X' (notin K X').
rec notin_propagates_to_target: (g:ctx) [g ⊢ ccsk.fstep X (kl_base α M[]) X'] →
  [g ⊢ notin K[] X] → [g ⊢ neq M[] K[]] → [g ⊢ notin K[] X'] =
/ total f (notin_propagates_to_target _ _ _ _ _ _ f _ _) /
fn f,n,i ⇒ case f of
  | [g ⊢ fs_pref _] ⇒ let [g ⊢ not_pref N] = n in
    let [g ⊢ I] = symmetric_neq i in [g ⊢ not_kpref I N]
  | [g ⊢ fs_kpref F _] ⇒ let [g ⊢ not_kpref I' N] = n in
    let [g ⊢ N'] = notin_propagates_to_target [g ⊢ F] [g ⊢ N] i in [g ⊢ not_kpref I' N']
  | [g ⊢ fs_suml F1 _] ⇒ let [g ⊢ not_sum N1 N2] = n in
    let [g ⊢ N1'] = notin_propagates_to_target [g ⊢ F1] [g ⊢ N1] i in [g ⊢ not_sum N1' N2]
  | [g ⊢ fs_sumr F2 _] ⇒ let [g ⊢ not_sum N1 N2] = n in
    let [g ⊢ N2'] = notin_propagates_to_target [g ⊢ F2] [g ⊢ N2] i in [g ⊢ not_sum N1 N2']
  | [g ⊢ fs_parl F1 _] ⇒ let [g ⊢ not_par N1 N2] = n in
    let [g ⊢ N1'] = notin_propagates_to_target [g ⊢ F1] [g ⊢ N1] i in [g ⊢ not_par N1' N2]
  | [g ⊢ fs_parr F2 _] ⇒ let [g ⊢ not_par N1 N2] = n in
    let [g ⊢ N2'] = notin_propagates_to_target [g ⊢ F2] [g ⊢ N2] i in [g ⊢ not_par N1 N2']
  | [g ⊢ fs_synl F1 F2] ⇒ let [g ⊢ not_par N1 N2] = n in
    let [g ⊢ N1'] = notin_propagates_to_target [g ⊢ F1] [g ⊢ N1] i in
    let [g ⊢ N2'] = notin_propagates_to_target [g ⊢ F2] [g ⊢ N2] i in [g ⊢ not_par N1' N2']
  | [g ⊢ fs_synr F1 F2] ⇒ let [g ⊢ not_par N1 N2] = n in
    let [g ⊢ N1'] = notin_propagates_to_target [g ⊢ F1] [g ⊢ N1] i in
    let [g ⊢ N2'] = notin_propagates_to_target [g ⊢ F2] [g ⊢ N2] i in [g ⊢ not_par N1' N2']
  | [g ⊢ fs_nu \a.F] ⇒ let [g ⊢ not_nu \a.N] = n in
    let [g ⊢ I] = i in
    let [g,a:names ⊢ N'] = notin_propagates_to_target [_ ⊢ F] [_ ⊢ N] [_ ⊢ I[..]] in [g ⊢ not_nu \a.N']
;

% Given a forward transition F: X --[α K]--> Y, the target process Y contains the key K.
% More precisely, we prove that notin K Y gives a contradiction.
rec key_in_target_of_fstep: (g:ctx) [g ⊢ ccsk.fstep X (kl_base α K[]) Y] → [g ⊢ notin K[] Y] → [g ⊢ false] =
/ total f (key_in_target_of_fstep _ _ _ _ _ f _) /
fn f,n ⇒ case f of
  | [g ⊢ fs_pref _] ⇒ let [g ⊢ not_kpref I _] = n in impossible irreflexive_neq [g ⊢ I]
  | [g ⊢ fs_kpref F _] ⇒ let [g ⊢ not_kpref _ N] = n in
    impossible key_in_target_of_fstep [g ⊢ F] [g ⊢ N]
  | [g ⊢ fs_suml F D] ⇒ let [g ⊢ not_sum N _] = n in
    impossible key_in_target_of_fstep [g ⊢ F] [g ⊢ N]
  | [g ⊢ fs_sumr F D] ⇒ let [g ⊢ not_sum _ N] = n in
    impossible key_in_target_of_fstep [g ⊢ F] [g ⊢ N]
  | [g ⊢ fs_parl F _] ⇒ let [g ⊢ not_par N _] = n in
    impossible key_in_target_of_fstep [g ⊢ F] [g ⊢ N]
  | [g ⊢ fs_parr F _] ⇒ let [g ⊢ not_par _ N] = n in
    impossible key_in_target_of_fstep [g ⊢ F] [g ⊢ N]
  | [g ⊢ fs_synl F _] ⇒ let [g ⊢ not_par N _] = n in
    impossible key_in_target_of_fstep [g ⊢ F] [g ⊢ N]
  | [g ⊢ fs_synr F _] ⇒ let [g ⊢ not_par N _] = n in
    impossible key_in_target_of_fstep [g ⊢ F] [g ⊢ N]
  | [g ⊢ fs_nu \a.F] ⇒ let [g ⊢ not_nu \a.N] = n in
    impossible key_in_target_of_fstep [_ ⊢ F] [_ ⊢ N]
;

% Two forward composable transitions cannot have the same key.
rec ccsk_no_composable_fw_tr_with_same_key: (g:ctx) [g ⊢ ccsk.fstep X (kl_base α1 K[]) Y] →
  [g ⊢ ccsk.fstep Y (kl_base α2 K[]) Z] → [g ⊢ false] =
/ total x (ccsk_no_composable_fw_tr_with_same_key _ x _ _ _ _ _ _ _) /
fn f1,f2 ⇒ let [g ⊢ F1] = f1 in
let [g ⊢ F2] = f2 in
(case total_enrich_f [g ⊢ F1] of
  | [g ⊢ ex_enfc (en_fc _ F1+ _ H1)] ⇒ (case total_enrich_f [g ⊢ F2] of
       | [g ⊢ ex_enfc (en_fc _ F2+ _ H2)] ⇒ impossible no_composable_fw_tr_with_same_key [g ⊢ fc F1+] [g ⊢ fc F2+] [g ⊢ key_cl H1] [g ⊢ key_cl H2]
       | [g ⊢ ex_enfo (en_fo _ F2+ \a.H2)] ⇒ impossible no_composable_fw_tr_with_same_key [g ⊢ fc F1+] [g ⊢ fo F2+] [g ⊢ key_cl H1] [g ⊢ key_op \a.H2])
  | [g ⊢ ex_enfo (en_fo _ F1+ \a.H1)] ⇒ (case total_enrich_f [g ⊢ F2] of
       | [g ⊢ ex_enfc (en_fc _ F2+ _ H2)] ⇒ impossible no_composable_fw_tr_with_same_key [g ⊢ fo F1+] [g ⊢ fc F2+] [g ⊢ key_op \a.H1] [g ⊢ key_cl H2]
       | [g ⊢ ex_enfo (en_fo _ F2+ \a.H2)] ⇒ impossible no_composable_fw_tr_with_same_key [g ⊢ fo F1+] [g ⊢ fo F2+] [g ⊢ key_op \a.H1] [g ⊢ key_op \a.H2]))
;

% Two forward composable transitions cannot have the same keyed label.
rec ccsk_no_composable_fw_tr_with_same_label: (g:ctx) [g ⊢ ccsk.fstep X KL Y] → [g ⊢ ccsk.fstep Y KL Z] → [g ⊢ false] =
/ total x (ccsk_no_composable_fw_tr_with_same_label _ x _ _ _ _ _) /
fn f1,f2 ⇒ let [g ⊢ F1]:[g ⊢ ccsk.fstep _ (kl_base _ _) _] = f1 in 
impossible ccsk_no_composable_fw_tr_with_same_key [g ⊢ F1] f2
;

% Two backward composable transitions cannot have the same keyed label.
rec ccsk_no_composable_bw_tr_with_same_label: (g:ctx) [g ⊢ ccsk.bstep Z KL Y] → [g ⊢ ccsk.bstep Y KL X] → [g ⊢ false] =
/ total x (ccsk_no_composable_bw_tr_with_same_label _ x _ _ _ _ _) /
fn b1,b2 ⇒ let [g ⊢ B1]:[g ⊢ ccsk.bstep _ (kl_base _ _) _] = b1 in 
let [g ⊢ F1] = ccsk_loop_lemma_two [g ⊢ B1] in
let [g ⊢ F2] = ccsk_loop_lemma_two b2 in
impossible ccsk_no_composable_fw_tr_with_same_key [g ⊢ F2] [g ⊢ F1]
;

% Given a combined transition t, t and inv_tr(t) have opposite directions.
rec ccsk_inv_tr_have_opp_direction: (g:ctx) (S1:[g ⊢ ccsk.step X1 KL1 X1']) (S2:[g ⊢ ccsk.step X2 KL2 X2'])
  [g ⊢ ccsk_inv_tr S1 S2] → [g ⊢ ccsk_opp_direction S1 S2] =
/ total hr (ccsk_inv_tr_have_opp_direction _ _ _ _ _ _ _ _ _ hr) /
fn hr ⇒ let [g ⊢ ccsk_it S1 S2] = hr in
case [_ ⊢ S1] of
  | [g ⊢ fw F1] ⇒ (case [g ⊢ S2] of
       | [g ⊢ fw F2] ⇒ impossible ccsk_no_composable_fw_tr_with_same_label [g ⊢ F1] [g ⊢ F2]
       | [g ⊢ bw B2] ⇒ [g ⊢ ccsk_odfb])
  | [g ⊢ bw B1] ⇒ (case [g ⊢ S2] of
       | [g ⊢ fw F2] ⇒ [g ⊢ ccsk_odbf]
       | [g ⊢ bw B2] ⇒ impossible ccsk_no_composable_bw_tr_with_same_label [g ⊢ B1] [g ⊢ B2])
;


% Given CCSK combined transitions T1: step X (kl_base α K) Z1, T2: step X (kl_base γ K) Z2,
% U1: step Y (kl_base β M) Z1] and U2: step Y (kl_base δ M) Z2, that use distinct keys K and M
% and such that (T1,T2) and (U1,U2) have same direction, then the two processes Z1 and Z2 are equal.
% As a consequence, for the uniqueness of derivation trees of transitions, T1=T2 and U1=U2.

% We first prove the result by cases, according to the direction of Ti and Ui, i=1,2.

% (T1,T2) and (U1,U2) are all forward
rec unique_diamonds_ff: (g:ctx) {F1:[g ⊢ ccsk.fstep X (kl_base α K[]) Z1]} {F2:[g ⊢ ccsk.fstep X (kl_base γ K[]) Z2]}
  {G1:[g ⊢ ccsk.fstep Y (kl_base β M[]) Z1]} {G2:[g ⊢ ccsk.fstep Y (kl_base δ M[]) Z2]} [g ⊢ neq K[] M[]] → [g ⊢ eqp Z1 Z2] =
/ total t1 (unique_diamonds_ff _ _ _ _ _ _ _ _ _ _ _ t1 _ _ _ _) /
mlam F1,F2,G1,G2 ⇒ fn i ⇒ case [_ ⊢ F1] of
  | [g ⊢ fs_pref DF1] ⇒ (case [g ⊢ G1] of
       | [g ⊢ fs_pref _] ⇒ impossible irreflexive_neq i
       | [g ⊢ fs_kpref G1' _] ⇒ impossible target_is_not_std [g ⊢ G1'] [g ⊢ DF1])
  | [g ⊢ fs_kpref F1' _] ⇒ (case [g ⊢ G1] of
       | [g ⊢ fs_pref DG1] ⇒ impossible target_is_not_std [g ⊢ F1'] [g ⊢ DG1]
       | [g ⊢ fs_kpref G1' _] ⇒ let [g ⊢ fs_kpref F2' _] = [g ⊢ F2] in
         let [g ⊢ fs_kpref G2' _] = [g ⊢ G2] in 
         let [g ⊢ refp] = unique_diamonds_ff [g ⊢ F1'] [g ⊢ F2'] [g ⊢ G1'] [g ⊢ G2'] i in [g ⊢ refp])
  | [g ⊢ fs_suml FL1 DF1] ⇒ (case [g ⊢ G1] of
       | [g ⊢ fs_suml GL1 _] ⇒ (case [g ⊢ F2] of
            | [g ⊢ fs_suml FL2 DF2] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_suml GL2 _] ⇒ 
                   let [g ⊢ refp] = unique_diamonds_ff [g ⊢ FL1] [g ⊢ FL2] [g ⊢ GL1] [g ⊢ GL2] i in [g ⊢ refp]
                 | [g ⊢ fs_sumr GR2 _] ⇒ impossible target_is_not_std [g ⊢ GR2] [g ⊢ DF2])
            | [g ⊢ fs_sumr FR2 DF2] ⇒ (case [g ⊢ G2] of
                 | [g ⊢ fs_suml GL2 _] ⇒ impossible target_is_not_std [g ⊢ GL2] [g ⊢ DF2]
                 | [g ⊢ fs_sumr GR2 _] ⇒ let [g ⊢ I]:[g ⊢ neq K[] M[]] = i in
                   let [g ⊢ N] = no_key_in_std [⊢ M] [g ⊢ DF2] in 
                   let [g ⊢ N'] = notin_propagates_to_target [g ⊢ FL1] [g ⊢ N] [g ⊢ I] in
                   impossible key_in_target_of_fstep [g ⊢ GL1] [g ⊢ N']))
       | [g ⊢ fs_sumr GR1 _] ⇒ impossible target_is_not_std [g ⊢ GR1] [g ⊢ DF1])
  | [g ⊢ fs_sumr FR1 DF1] ⇒ (case [g ⊢ G1] of
       | [g ⊢ fs_suml GL1 _] ⇒ impossible target_is_not_std [g ⊢ GL1] [g ⊢ DF1]
